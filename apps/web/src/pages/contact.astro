---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Local Live Music Tracker">
	<main class="container mx-auto px-4 py-12 max-w-2xl">
		<h1 class="text-4xl font-bold mb-8 text-brand-primary">Contact Us</h1>
		
		<div class="prose prose-lg max-w-none">
			<p class="mb-6">
				Have a request, removal, issue, or update? We're here to help keep Demo City's music scene accurate and accessible.
			</p>
			
			<div class="bg-white p-8 rounded-xl border border-brand-primary/10 shadow-sm mb-8">
				<h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
					<span class="text-2xl">📧</span> Email Us
				</h2>
				<p class="text-lg mb-6">
					Have a request or update? Click the button below to reach out.
				</p>
				<button 
					id="contact-btn"
					class="inline-flex items-center gap-2 bg-[#0059b3] text-white px-6 py-3 rounded-lg font-bold hover:bg-[#004a96] transition-all shadow-md active:scale-95 group"
				>
					Send us a Message
					<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
				</button>
				<p id="fallback-link" class="mt-4 text-sm text-gray-500 hidden">
					Or manually email: <span id="encoded-email"></span>
				</p>
			</div>

			<script>
				const btn = document.getElementById('contact-btn');
				
				// Obfuscated parts
				const user = 'hello';
				const domain = 'mkestack.com';
				
				btn?.addEventListener('click', () => {
					window.location.href = `mailto:${user}@${domain}`;
				});

				// Optional: Show encoded email for accessibility (e.g. if mailto fails)
				// but only after a delay or interaction to deter simple scrapers
				setTimeout(() => {
					const encoded = document.getElementById('encoded-email');
					const fallback = document.getElementById('fallback-link');
					if (encoded && fallback) {
						encoded.textContent = `${user}@${domain}`;
						fallback.classList.remove('hidden');
					}
				}, 2000);
			</script>

			<h2 class="text-2xl font-bold mt-12 mb-4 text-brand-primary">What can we help with?</h2>
			<ul class="space-y-4">
				<li class="flex gap-4 items-start">
					<span class="bg-brand-secondary/20 p-2 rounded-full text-sm">✓</span>
					<div>
						<strong>Add a Show:</strong> Missing an event? Send us the details and we'll get it listed.
					</div>
				</li>
				<li class="flex gap-4 items-start">
					<span class="bg-brand-secondary/20 p-2 rounded-full text-sm">✓</span>
					<div>
						<strong>Update Information:</strong> Notice a mistake? Let us know so we can fix it.
					</div>
				</li>
				<li class="flex gap-4 items-start">
					<span class="bg-brand-secondary/20 p-2 rounded-full text-sm">✓</span>
					<div>
						<strong>Removal Requests:</strong> If you represent an artist or venue and need a listing removed.
					</div>
				</li>
				<li class="flex gap-4 items-start">
					<span class="bg-brand-secondary/20 p-2 rounded-full text-sm">✓</span>
					<div>
						<strong>Technical Issues:</strong> Site not working right? Report bugs to us.
					</div>
				</li>
			</ul>
		</div>
	</main>
</Layout>
