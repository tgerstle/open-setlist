---
import Layout from "../layouts/Layout.astro";
import { getEvents, getVenuesOverview } from "../../../src/db/admin-queries";
import { FilterBar } from "../components/ui/FilterBar";
import { DailyFeedView } from "../components/views/DailyFeedView";
import { DataOrchestrator } from "../components/logic/DataOrchestrator";
import { ShowDetailDrawerContainer } from "../components/ui/ShowDetailDrawerContainer";
import Database from "better-sqlite3";
import { resolve } from "node:path";

export const prerender = true;

const today = new Date().toISOString().split("T")[0];
const { data: initialShows } = getEvents(
  undefined,
  1,
  100,
  "date",
  "ASC",
  today,
);
const rawVenues = getVenuesOverview()
  .filter((v) => (v.upcoming_shows || 0) + (v.passed_shows || 0) > 0)
  .map((v) => {
    return {
      id: v.venue_id,
      name: v.venue_name,
      short_name: v.short_name,
      theme_color: v.theme_color,
      website_url: v.website_url,
      coordinates: v.coordinates,
    };
  });

console.log("ASTRO RAW VENUES [0]:", rawVenues[0]);

const DB_PATH = resolve("../data/localmusic.db");
const db = new Database(DB_PATH, { readonly: true });
const allDates = db.prepare(`SELECT event_date as date FROM shows`).all() as {
  date: string;
}[];
db.close();

const monthSet = new Set<string>();
allDates.forEach((row) => {
  monthSet.add(row.date.substring(0, 7));
});
const availableMonths = Array.from(monthSet).sort();

const initialManifest = {
  availableMonths: availableMonths,
  totalShows: allDates.length,
  lastUpdated: new Date().toISOString(),
};
---

<Layout title="Local Live Music Tracker" activeView="feed">
  <div class="sticky top-14 z-40">
    <FilterBar client:only="react" initialVenues={rawVenues}>
      <div
        slot="fallback"
        class="w-full border-b border-[rgba(0,0,0,0.1)] py-[10px] px-4 md:px-6 bg-white"
      >
        <div class="max-w-7xl mx-auto flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div
              class="h-10 w-[142px] bg-slate-100 rounded-md border border-slate-200 animate-pulse"
            >
            </div>
          </div>
        </div>
      </div>
    </FilterBar>
  </div>
  <main class="min-h-dvh flex-1 w-full max-w-7xl mx-auto px-4 md:px-6 py-8">
    <DataOrchestrator
      client:load
      initialShows={initialShows}
      initialVenues={rawVenues}
      initialView="feed"
    />
    <DailyFeedView client:only="react" initialShows={initialShows} />
    <ShowDetailDrawerContainer client:idle />
  </main>
</Layout>
