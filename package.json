{
  "name": "local-live-music-tracker",
  "version": "0.1.0",
  "description": "Root orchestrator for MKE Setlist scraper and frontend",
  "private": true,
  "scripts": {
    "venue:scaffold": "tsx bin/scaffold-venue.ts",
    "db:init": "sqlite3 data/mkesetlist.db < src/db/schema.sql && sqlite3 data/mkesetlist.db < src/db/seed.sql",
    "db:geocode": "sqlite3 data/mkesetlist.db < src/db/geocode_seed.sql",
    "scrape": "tsx scraper/core/runner.ts && npm run build",
    "show:engine": "tsx scraper/enrichment/show_engine.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "web:install": "cd astro-app && npm install",
    "web:dev": "cd astro-app && npm run dev",
    "web:build": "cd astro-app && npm run build",
    "web:preview": "cd astro-app && npm run preview",
    "build": "npm run web:build",
    "dev": "npm run web:dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/better-sqlite3": "^7.6.0",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "playwright": "^1.40.0",
    "storybook": "^10.3.6",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "node-ical": "^0.26.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
